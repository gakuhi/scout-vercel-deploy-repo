#!/bin/sh

# main / staging ブランチへの直接 push を禁止する
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "main" ] || [ "$current_branch" = "staging" ]; then
  echo ""
  echo "ERROR: ${current_branch} ブランチへの直接 push は禁止されています。"
  echo "feature ブランチから PR を作成してください。"
  echo ""
  exit 1
fi
