# ========================================
# Supabase（Scout 自身）
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# サイト設定
# ========================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ========================================
# LINE Login
# ========================================
LINE_LOGIN_CHANNEL_ID=your-line-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-line-channel-secret

# ========================================
# 同時登録: 内部状態暗号化
# ========================================
# state の暗号化用キー（32 バイト hex = 64 文字）
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCOUT_STATE_ENCRYPTION_KEY=your-64-char-hex-string

# ========================================
# 同時登録: HMAC 署名の秘密鍵（プロダクトごと）
# ========================================
# プロダクト側と共有する秘密鍵。プロダクトごとに個別の値を生成すること
# 生成: openssl rand -hex 32
SCOUT_HMAC_SECRET_SMARTES=your-hmac-secret
SCOUT_HMAC_SECRET_INTERVIEWAI=your-hmac-secret
SCOUT_HMAC_SECRET_COMPAI=your-hmac-secret
SCOUT_HMAC_SECRET_SUGOSHU=your-hmac-secret

# ========================================
# 同時登録: callback_url ホワイトリスト（プロダクトごと）
# ========================================
ALLOWED_CALLBACK_SMARTES=https://smartes.example.com
ALLOWED_CALLBACK_INTERVIEWAI=https://interviewai.example.com
ALLOWED_CALLBACK_COMPAI=https://compai.example.com
ALLOWED_CALLBACK_SUGOSHU=https://sugoshu.example.com

# ========================================
# データ連携: 外部プロダクト DB 接続情報
# ========================================

# スマートES（PlanetScale Read-only パスワード）
SMARTES_PS_HOST=aws.connect.psdb.cloud
SMARTES_PS_USER=your-planetscale-user
SMARTES_PS_PASS=your-planetscale-password

# 面接練習AI（Supabase Transaction Pooler 経由、scout_reader ロール）
# 形式: postgresql://scout_reader.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
INTERVIEWAI_DB_URL=

# 企業分析AI（Supabase Transaction Pooler 経由、scout_reader ロール）
# 形式: postgresql://scout_reader.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
COMPAI_DB_URL=

# すごい就活（Bubble Data API）
# 末尾 "/obj" まで含める。probe / sync は /{type}?limit=... を連結
# 例（Live）: https://sugoshu.kokoshiro.jp/api/1.1/obj
# 例（Dev） : https://sugoshu.kokoshiro.jp/version-test/api/1.1/obj
SUGOSHU_BUBBLE_API_URL=
SUGOSHU_BUBBLE_API_KEY=


# ========================================
# Vercel Cron 認証（日次同期ジョブ用）
# ========================================
# 生成: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ========================================
# Claude API（統合プロフィール生成・マッチング）
# ========================================
ANTHROPIC_API_KEY=your-anthropic-api-key
